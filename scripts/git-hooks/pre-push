#!/bin/bash
# Full local gate: everything pre-commit runs, plus stylelint and the
# production build. CI still audits the deployed site (smoke, axe,
# Lighthouse) — this hook catches what a build can catch before the
# round-trip.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "pre-push: oxlint + stylelint + tsc + vitest + build..."
npm run lint
npm run lint:css
npx tsc -b
npx vitest run --reporter=dot
npm run build

echo "pre-push: axe sweep against the built app..."
npm run preview >/dev/null 2>&1 &
preview_pid=$!
trap 'kill $preview_pid 2>/dev/null' EXIT
sleep 2
SMOKE_URL=http://localhost:4173/ChosenPicachu/ npx playwright test a11y --reporter=line
echo "pre-push: clean."
